    <title>前端判断数据类型</title>
    <link href="https://halely.github.io/2021/08/16/%E5%89%8D%E7%AB%AF%E5%88%A4%E6%96%AD%E6%95%B0%E6%8D%AE%E7%B1%BB%E5%9E%8B/"/>
    <id>https://halely.github.io/2021/08/16/%E5%89%8D%E7%AB%AF%E5%88%A4%E6%96%AD%E6%95%B0%E6%8D%AE%E7%B1%BB%E5%9E%8B/</id>
